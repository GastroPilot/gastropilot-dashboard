# ===========================================
# Gastropilot Frontend - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# API Configuration
# -----------------
# Die API-URL wird automatisch basierend auf der Frontend-Domain generiert:
#   - localhost → http://localhost:8001
#   - gpilot.app → https://api.gpilot.app (Prod)
#   - {kunde}.gpilot.app → https://api-{kunde}.gpilot.app
#   - staging.gpilot.app → https://api-staging.gpilot.app
#   - demo.gpilot.app → https://api-demo.gpilot.app
#
# Optional: Überschreibe die automatische URL-Generierung (Client-seitig)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
# Für Setup ohne nginx-Gateway kannst du Orders separat auf 8001 routen:
# NEXT_PUBLIC_ORDERS_API_BASE_URL=http://localhost:8001
# Für Setup ohne nginx-Gateway kannst du AI separat auf 8002 routen:
# NEXT_PUBLIC_AI_API_BASE_URL=http://localhost:8002

# Server-Side Rendering API URL (für Docker/Container-Umgebungen)
# WICHTIG: Im Container kann localhost das Backend nicht erreichen!
# Verwende den Container-Namen (z.B. http://backend:8000) oder host.docker.internal
# SSR_API_BASE_URL=http://backend:8000

# Optional: API-Versions-Präfix (Standard: v1)
# NEXT_PUBLIC_API_PREFIX=v1

# Optional: Debug-Logs im API-Client aktivieren (standardmäßig aus)
# NEXT_PUBLIC_API_DEBUG=false

# App Version (automatically set during CI/CD builds)
NEXT_PUBLIC_APP_VERSION=dev

# Optional: Sentry DSN for error tracking
# NEXT_PUBLIC_SENTRY_DSN=

# Optional: Analytics
# NEXT_PUBLIC_ANALYTICS_ID=
