# API-Konfiguration (für Client-seitigen Code müssen Variablen mit NEXT_PUBLIC_ beginnen)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
NEXT_PUBLIC_API_PREFIX=v1

# Server-seitige API-Konfiguration (Fallback, wird nur verwendet wenn NEXT_PUBLIC_ nicht gesetzt ist)
API_BASE_URL=http://localhost:8001
API_PREFIX=v1

NEXT_PUBLIC_APP_VERSION=1.0.0
